class Solution {
public:
    vector<int> nextGreaterElements(vector<int>& nums) {
        int n = nums.size();
        stack<int> st;
        vector<int> nge(n);

        // Traverse the array twice (from right to left) to simulate circular
        // array
        for (int i = 2 * n - 1; i >= 0; i--) {
            // Remove all elements that are smaller than or equal to current
            // element
            while (!st.empty() && st.top() <= nums[i % n])
                st.pop();

            // Only fill answers during the first pass (i < n)
            if (i < n) {
                // If stack is empty, no greater element exists
                // Otherwise, top of stack is the next greater element
                if (st.empty())
                    nge[i] = -1;
                else
                    nge[i] = st.top();
            }
            st.push(nums[i % n]);
        }
        return nge;
    }
};
