class Solution {
	public:
	vector<int> nextSmallerEle(vector<int>& arr) {
		int n = arr.size();
		stack<int> st; // Monotonic increasing stack
		vector<int> nse(n);
		
		// Traverse the array from right to left
		for (int i = n - 1; i >= 0; i--) {
			// Remove all elements greater than or equal to the current element
			// since they cannot be the next smaller element
			while (!st.empty() && st.top() >= arr[i])
				st.pop();
			
			// If the stack is empty, no smaller element exists on the right
			// Otherwise, the top of the stack is the next smaller element
			nse[i] = st.empty() ? -1: st.top();
			
			st.push(arr[i]);
		}
		return nse;
	}
};
