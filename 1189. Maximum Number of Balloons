// Logic:
//
// 1. Count the frequency of every character present in the input string.
//
// 2. Store the frequency of each character required to form the word
//    "balloon":
//       b -> 1
//       a -> 1
//       l -> 2
//       o -> 2
//       n -> 1
//
// 3. For every required character, calculate how many complete
//    "balloon" words it can contribute to by dividing its available
//    frequency by its required frequency.
//
// 4. The character that can form the fewest complete words becomes
//    the limiting factor.
//
// 5. Return this minimum value as the maximum number of times
//    the word "balloon" can be formed.

class Solution {
public:
    int maxNumberOfBalloons(string text) {

        // Count the frequency of each character in the input string
        unordered_map<char, int> have;
        for (char ch : text)
            have[ch]++;

        // Frequency of each character required to form "balloon"
        unordered_map<char, int> need;
        need['b'] = 1;
        need['a'] = 1;
        need['l'] = 2;
        need['o'] = 2;
        need['n'] = 1;

        // Store the maximum number of complete "balloon" words possible
        int ans = INT_MAX;

        // Check each required character
        for (auto i : need) {
            char c = i.first;      // Current character
            int f_need = i.second; // Required frequency in "balloon"
            int f_have = have[c];  // Available frequency in the input

            // Number of times this character can contribute
            int times = f_have / f_need;

            // The limiting character determines the final answer
            ans = min(ans, times);
        }

        return ans;
    }
};
