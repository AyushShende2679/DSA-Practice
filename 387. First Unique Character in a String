class Solution {
public:
    int firstUniqChar(string s) {
        // Get the length of the string
        int n = s.size();

        // Array to store the frequency of each lowercase letter (a-z)
        int unique[26] = {0};

        // First pass: Count the frequency of every character
        for (int i = 0; i < n; i++) {
            char ch = s[i];
            unique[ch - 'a']++;
        }

        // Second pass: Find the first character
        // whose frequency is exactly 1
        for (int i = 0; i < n; i++) {
            char ch = s[i];

            // Return the index of the first unique character
            if (unique[ch - 'a'] == 1)
                return i;
        }

        // Return -1 if there is no unique character
        return -1;
    }
};
