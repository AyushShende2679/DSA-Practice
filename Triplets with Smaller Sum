class Solution {
	public:
	int countTriplets(int sum, vector<int>& arr) {
		int n = arr.size();
		sort(arr.begin(), arr.end());
		int count = 0;
		
		for (int i = 0; i<n; i++) {
			int j = i + 1, k = n - 1;
			while (j < k) {
				if (arr[i]+arr[j]+arr[k]<sum) {
					//  found that the largest possible third element already satisfies the condition,
					// so all elements between j+1 and k are automatically valid. Count them all at once."
					count += (k - j);
					j++;
				} else {
					k--;
				}
			}
		}
		return count;
	}
};
