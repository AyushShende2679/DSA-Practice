/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* deleteDuplicates(ListNode* head) {
        if (head == nullptr)
            return head;
        ListNode* curr = head;
        ListNode* tail = head->next;

        while (tail != nullptr) {
            if (curr->val == tail->val) {
                ListNode* temp = tail;
                curr->next = temp->next;
                tail = tail->next;
                delete temp;
            } else {
                curr = curr->next;
                tail = tail->next;
            }
        }
        return head;
    }
};
