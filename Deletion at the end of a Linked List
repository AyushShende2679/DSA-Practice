class Solution {
	public:
	Node* removeLastNode(Node* head) {
		if (head == NULL)
			return NULL;
		// Only one node
		if (head->next == NULL) {
			delete head;
			return NULL;
		}
		Node* temp = head;
		
		while (temp->next != NULL && temp->next->next != NULL)
			temp = temp->next;
			
		Node* delNode = temp->next;
		temp->next = NULL;
		delete delNode;
		
		return head;
	}
};
