class Solution {
public:
    int Sum(int n) {
        int sum = 0;
        while (n > 0) {
            int d = n % 10; // Extract the last digit
            sum += d * d;   // Add square of the digit
            n /= 10;        // Remove the last digit
        }
        return sum;
    }
    bool isHappy(int n) {
        int slow = n, fast = n;

        while (fast != 1) {
            slow = Sum(slow);      // 1 step
            fast = Sum(Sum(fast)); // 2 step

            // If both pointers meet at a number other than 1,
            // a cycle exists and the number is not happy
            if (slow == fast && slow != 1)
                return false;
        }
        return true;
    }
};
