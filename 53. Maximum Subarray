// Keep extending the current subarray as long as it helps. If it starts hurting (sum becomes negative), start a new subarray from the next element.
class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int sum = 0, maxSum = INT_MIN;

        for (int i = 0; i < nums.size(); i++) {
            sum += nums[i];
            maxSum = max(maxSum, sum);

            if (sum < 0)
                sum = 0;
        }
        return maxSum;
    }
};
