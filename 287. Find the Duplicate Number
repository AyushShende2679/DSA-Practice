class Solution {
public:
    // Floyd's cycle pattern
    int findDuplicate(vector<int>& nums) {
        int slow = 0, fast = 0;

        // detect intersection inside the cycle
        do {
            slow = nums[slow];
            fast = nums[nums[fast]];
        } while (slow != fast);

        //  find entry point of cycle = the duplicate number
        slow = 0;
        while (slow != fast) {
            slow = nums[slow];
            fast = nums[fast];
        }
        return slow;
    }
};
