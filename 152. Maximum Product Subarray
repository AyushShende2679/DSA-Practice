// Logic:
// 1. Traverse the array from both left-to-right (prefix) and right-to-left (suffix).
// 2. Maintain running products in both directions.
// 3. If any running product becomes 0, reset it to 1 since a new subarray starts after 0.
// 4. At each step, compare both prefix and suffix products with the current maximum product.
// 5. Scanning from both directions ensures that cases with odd negative numbers are handled,
//    as excluding either the leftmost or rightmost negative element can produce the maximum product.
// 6. Return the maximum product obtained during the traversal.

class Solution {
public:
    int maxProduct(vector<int>& nums) {
        int n = nums.size();
        int prefix = 1; // Stores product from left to right
        int suffix = 1; // Stores product from right to left
        int maxProduct = INT_MIN;

        for (int i = 0; i < n; i++) {
            // If a zero was encountered, restart the prefix product
            if (prefix == 0)
                prefix = 1;
            // If a zero was encountered, restart the suffix product
            if (suffix == 0)
                suffix = 1;
            prefix = prefix * nums[i];   // Update prefix product (left to right)
            suffix = suffix * nums[n - i - 1]; // Update suffix product (right to left)


            // Update the maximum product using both directions
            maxProduct = max(maxProduct, max(prefix, suffix));
        }
        return maxProduct;
    }
};
