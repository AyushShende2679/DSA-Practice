/*
Logic:

1. Sort all intervals by their starting time.
   This ensures that if two intervals overlap, they will appear next to each other.

2. Assume the first interval is our current merged interval.

3. Go through the remaining intervals one by one.

4. If the next interval overlaps with the current merged interval,
   do NOT store anything yet.
   Just extend the end of the current merged interval because
   another interval might also overlap with it.

5. If the next interval does NOT overlap,
   it means the current merged interval is complete.
   Store it in the answer and start a new current interval
   from the non-overlapping interval.

6. After the loop ends,
   store the last current merged interval because
   there is no next interval left to trigger the "store" step.

Example:
[1,3] [2,6] [5,8] [10,12]

Current = [1,3]
↓ overlaps
Current = [1,6]
↓ overlaps
Current = [1,8]
↓ no overlap
Store [1,8]
Current = [10,12]

Loop ends
Store [10,12]

Answer = [[1,8], [10,12]]
*/

class Solution {
public:
    vector<vector<int>> merge(vector<vector<int>>& intervals) {
        int n = intervals.size();
        vector<vector<int>> res;
        sort(intervals.begin(), intervals.end());
        // Current interval that we are trying to merge
        int start1 = intervals[0][0];
        int end1 = intervals[0][1];

        // Traverse the remaining intervals
        for (int i = 1; i < n; i++) {
            int start2 = intervals[i][0];
            int end2 = intervals[i][1];

            // If the current interval overlaps with the next interval
            if (end1 >= start2) {
                end1 = max(end1, end2);
            } else // No overlap found
            {
                // Current merged interval is complete, so store it
                res.push_back({start1, end1});
                // Start a new interval
                start1 = start2;
                end1 = end2;
            }
        }
        res.push_back({start1, end1}); // Store the last merged interval
        return res;
    }
};
