class Solution {
public:
    // Returns the next index in the circular array.
    // Handles both positive and negative jumps.
    int getNext(vector<int>& nums, int i) {
        int n = nums.size();
        return ((i + nums[i]) % n + n) % n;
    }

    bool circularArrayLoop(vector<int>& nums) {
        int n = nums.size();

        for (int i = 0; i < n; i++) {
            if (nums[i] == 0)
                continue;

            bool forward = nums[i] > 0;
            // Floyd's Cycle Detection
            int slow = i, fast = i;

            while (true) {
                slow = getNext(nums, slow);
                // Direction change => invalid cycle.
                if ((nums[slow] > 0) != forward)
                    break;

                fast = getNext(nums, fast);
                if ((nums[fast] > 0) != forward)
                    break;

                fast = getNext(nums, fast);
                if ((nums[fast] > 0) != forward)
                    break;

                if (slow == fast) {
                    // Single-element self-loop is not allowed.
                    if (slow == getNext(nums, slow))
                        break;
                    return true;
                }
            }
            // Mark all nodes in this traversal as visited.
            // This ensures each index is processed at most once.
            int curr = i;
            while (nums[curr] != 0 && (nums[curr] > 0) == forward) {
                int next = getNext(nums, curr);
                nums[curr] = 0;
                curr = next;
            }
        }

        return false;
    }
};
