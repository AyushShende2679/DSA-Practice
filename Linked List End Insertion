class Solution {
	public:
	Node *insertAtEnd(Node *head, int x) { 
		Node* newNode = new Node(x); // create dummynode and insert val
		
		if (head == NULL)
			return newNode;  // if LL is empty return dummynode
		
		Node* temp = head;
		
		while (temp->next != NULL) {
			temp = temp->next;
		}
		temp ->next = newNode; // connect last node with new node 
		
		return head;
	}
};
