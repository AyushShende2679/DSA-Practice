class Solution {
public:
    vector<int> nextGreaterElement(vector<int>& nums1, vector<int>& nums2) {
        unordered_map<int, int> mp; // Stores {element -> next greater element}
        stack<int> st;              // Monotonic decreasing stack

        // Traverse in backwards and store next greater element
        for (int i = nums2.size() - 1; i >= 0; i--) {
            // Remove all elements smaller than or equal to the current element
            // since they cannot be the next greater element
            while (!st.empty() && st.top() <= nums2[i])
                st.pop();

            // If the stack is empty, no greater element exists
            // Otherwise, the top of the stack is the next greater element
            if (st.empty())
                mp[nums2[i]] = -1;
            else
                mp[nums2[i]] = st.top();

            st.push(nums2[i]);
        }

        vector<int> res;

        // find next greater element from map
        for (int i = 0; i < nums1.size(); i++)
            // res[i] = mp[nums1[i]];
            res.push_back(mp[nums1[i]]);

        return res;
    }
};
