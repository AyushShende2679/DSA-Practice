// Logic:
//
// 1. Calculate the total sum of the array.
//
// 2. Initialize leftSum = 0.
//
// 3. Traverse the array one element at a time.
//
// 4. At each index:
//    - Calculate the sum of elements on the right.
//      rightSum = totalSum - leftSum - currentElement
//
// 5. If leftSum == rightSum,
//    the current index is the middle (pivot) index.
//
// 6. If not,
//    add the current element to leftSum
//    and move to the next index.
//
// 7. If no such index is found,
//    return -1.

class Solution {
public:
    int findMiddleIndex(vector<int>& nums) {
        int n = nums.size();
        int totalSum = accumulate(nums.begin(), nums.end(), 0);
        int leftSum = 0, rightSum = 0;

        for (int i = 0; i < n; i++) {
            rightSum = totalSum - leftSum - nums[i];

            if (leftSum == rightSum)
                return i;
            leftSum += nums[i];
        }
        return -1;
    }
};
