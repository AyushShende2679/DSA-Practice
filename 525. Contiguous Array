/*
Logic:

1. Traverse the array once while maintaining a prefix sum.
2. Treat every 1 as +1 and every 0 as -1.
3. If the same prefix sum appears again, the elements between the two
   occurrences have an equal number of 0s and 1s.
4. Store the first occurrence of each prefix sum in a hash map.
5. Whenever a prefix sum repeats, calculate the subarray length and
   update the maximum length.
6. Initialize prefix sum 0 at index -1 so that subarrays starting from
   index 0 are also considered.
*/

class Solution {
public:
    int findMaxLength(vector<int>& nums) {
        int n = nums.size();
        int sum = 0, count = 0, maxLen = 0;
        unordered_map<int, int> mp;
        mp[0] = -1;

        for (int i = 0; i < n; i++) {
            // convert 0 into -1 and add it to sum
            sum += (nums[i] == 1) ? 1 : -1;

            // If this prefix sum has been seen before,
            // the subarray between the previous index and current index
            // contains an equal number of 0s and 1s.
            if (mp.find(sum) != mp.end()) {
                maxLen = max(maxLen, i - mp[sum]);
            } else {
                mp[sum] = i;
            }
        }
        return maxLen;
    }
};
