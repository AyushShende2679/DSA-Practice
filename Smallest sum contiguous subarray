class Solution {
	public:
	// Kadane's algorithm
	int smallestSumSubarray(vector<int>& a) {
		int sum = 0, minSum = INT_MAX;
		
		for (int i = 0; i<a.size(); i++) {
			
			sum += a[i]; // Extend the current subarray
			
			minSum = min(minSum, sum); // Update the minimum sum if the current sum is smaller
			
			// If the running sum becomes positive,
			// discard it because it cannot help form a smaller (more negative) subarray
			if (sum>0)
				sum = 0;
		}
		return minSum;
	}
};
