// 2 pointers approach 
class Solution {
public:
    void reverseString(vector<char>& s) {
        int n = s.size();
        int i = 0, j = n - 1;

        while (i < j) {
            swap(s[i], s[j]);
            i++;
            j--;
        }
    }
};
// OR - stack approach 
Time Complexity: O(n)
Space Complexity: O(N)
class Solution {
public:
    void reverseString(vector<char>& s) {
        stack<char> st;
        int n = s.size();

       // Push all characters onto the stack
        for (int i = 0; i < n; i++) {
            st.push(s[i]);
        }
        int i = 0; // re-initalize i , to store reverse character
        // Pop characters from the stack and place them
        // back into the vector in reverse order
        while (!st.empty()) {
            s[i] = st.top();
            st.pop();
            i++;
        }
    }
};
