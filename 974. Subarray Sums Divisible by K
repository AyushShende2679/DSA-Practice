/*
Logic:

1. Compute the prefix sum while traversing the array.

2. For each prefix sum, calculate its remainder when divided by k.

3. If the same remainder has been seen before, then the subarray
   between the previous occurrence(s) and the current index has a
   sum divisible by k.

   Reason:
   If
       prefixSum1 % k == prefixSum2 % k
   then
       (prefixSum2 - prefixSum1) % k == 0,
   which means the subarray sum is divisible by k.

4. Store the frequency of each remainder in a hash map.
   Whenever a remainder repeats, add its frequency to the answer.

5. Handle negative prefix sums by converting negative remainders
   to positive using:
       rem = (rem + k) % k

6. Initialize the map with remainder 0 having frequency 1 to account
   for subarrays starting from index 0 whose sum is divisible by k.

Time Complexity: O(n)
Space Complexity: O(k) (or O(n) in the worst case with a hash map)
*/

class Solution {
public:
    int subarraysDivByK(vector<int>& nums, int k) {
        int n = nums.size();
        unordered_map<int, int> mp;
        mp[0] = 1; // A remainder of 0 is initially present once (empty prefix)
        int prefixSum = 0;
        int count = 0;

        for (int i = 0; i < n; i++) {
            prefixSum += nums[i];
            int rem = prefixSum % k;

            if (rem < 0) // Convert negative remainder to positive
                rem += k;
                
            // If this remainder has appeared before,
            // then each previous occurrence forms a subarray
            // whose sum is divisible by k
            if (mp.find(rem) != mp.end()) {
                count += mp[rem];
            }
            mp[rem]++;
        }
        return count;
    }
};
