/*
Logic:

1. Compute the prefix sum while traversing the array.

2. For each prefix sum, calculate its remainder when divided by k.

3. If two prefix sums have the same remainder, then the difference
   between them (i.e., the subarray sum) is divisible by k.

4. Store the first occurrence of each remainder in a hash map.
   We keep the first occurrence because it gives the maximum possible
   subarray length.

5. Initialize the map with {0 : -1} to handle the case where a valid
   subarray starts from index 0.

6. Whenever the same remainder is encountered again, check whether
   the distance between the current index and the stored index is
   at least 2. If yes, a valid subarray exists.

Time Complexity: O(n)
Space Complexity: O(min(n, k)) (or O(n) in the worst case)
*/

class Solution {
public:
    bool checkSubarraySum(vector<int>& nums, int k) {
        int n = nums.size();
        int prefixSum = 0;
        unordered_map<int, int> mp;
        mp[0] = -1;

        for (int i = 0; i < n; i++) {
            prefixSum += nums[i];
            int rem = prefixSum % k;

            // If we've seen this remainder before,
            // then the subarray between the previous index + 1 and current
            // index has a sum divisible by k
            if (mp.find(rem) != mp.end()) {
                // Ensure the subarray length is at least 2
                if (i - mp[rem] >= 2)
                    return true;
            } else {
                mp[rem] = i;
            }
        }
        return false;
    }
};
